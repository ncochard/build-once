{
  "name": "build-once",
  "version": "0.0.1",
  "description": "Build your code, only if you need to...",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "yarn lint",
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "npx eslint src/ --fix",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "author": "Nicolas Cochard (nicolas@cochard.co.uk)",
  "license": "MIT",
  "homepage": "https://github.com/ncochard/build-once#readme",
  "bugs": {
    "url": "https://github.com/ncochard/build-once/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ncochard/build-once.git"
  },
  "bin": "./bin/build-once.js",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.13.2"
  },
  "dependencies": {
    "build-once-plugin": "^0.0.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.2",
    "execa": "^5.1.1",
    "globby": "^11.1.0",
    "mkdirp": "^3.0.1",
    "throat": "^6.0.2"
  }
}
