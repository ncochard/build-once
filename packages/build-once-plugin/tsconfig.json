{
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "module": "commonjs",
        "moduleResolution": "bundler",
        "target": "es2023",
        "lib": ["es2023", "dom", "es2023.intl"],
        "declaration": true,
        "strict": true,
        "resolveJsonModule": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": ["src/*.ts"]
}